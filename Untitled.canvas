		{"id":"2fd61197ec30d769","type":"text","text":"```mermaid\nerDiagram\n  users {\n    uuid id PK\n    string clerk_id\n    string email\n    string name\n    string avatar_url\n    bool is_premium\n    int read_count_this_month\n    string referral_code\n    timestamp created_at\n  }\n  companies {\n    uuid id PK\n    string name\n    string logo_url\n    string slug\n    int interview_count\n    timestamp created_at\n  }\n  interviews {\n    uuid id PK\n    uuid company_id FK\n    uuid user_id FK\n    string title\n    text content\n    string role\n    string location\n    int experience_years\n    int rounds_count\n    enum difficulty\n    enum outcome\n    decimal salary_lpa\n    string source_url\n    enum source_type\n    enum status\n    int confidence_score\n    timestamp created_at\n    timestamp published_at\n  }\n  interview_rounds {\n    uuid id PK\n    uuid interview_id FK\n    int round_number\n    string title\n    text questions\n    string difficulty\n    text notes\n    timestamp created_at\n  }\n  tags {\n    uuid id PK\n    string name\n  }\n  interview_tags {\n    uuid interview_id FK\n    uuid tag_id FK\n  }\n  bookmarks {\n    uuid id PK\n    uuid user_id FK\n    uuid interview_id FK\n    timestamp created_at\n  }\n  comments {\n    uuid id PK\n    uuid interview_id FK\n    uuid user_id FK\n    text content\n    bool is_deleted\n    timestamp created_at\n  }\n  referrals {\n    uuid id PK\n    uuid referrer_id FK\n    uuid referred_id FK\n    timestamp created_at\n  }\n  user_preferences {\n    uuid id PK\n    uuid user_id FK\n    text target_companies\n    string target_role\n    string experience_level\n    string interview_timeline\n    timestamp created_at\n    timestamp updated_at\n  }\n  read_history {\n    uuid id PK\n    uuid user_id FK\n    uuid interview_id FK\n    timestamp read_at\n  }\n  notifications {\n    uuid id PK\n    uuid user_id FK\n    enum type\n    string title\n    string body\n    string deep_link\n    bool is_read\n    timestamp created_at\n  }\n  fcm_tokens {\n    uuid id PK\n    uuid user_id FK\n    string token\n    enum platform\n    timestamp created_at\n  }\n  crawl_jobs {\n    uuid id PK\n    string source_url\n    text raw_text\n    enum status\n    int confidence_score\n    uuid interview_id FK\n    string error_message\n    timestamp created_at\n    timestamp processed_at\n  }\n\n  companies ||--o{ interviews : \"has\"\n  users ||--o{ interviews : \"submits\"\n  interviews ||--o{ interview_rounds : \"has\"\n  interviews ||--o{ interview_tags : \"tagged with\"\n  tags ||--o{ interview_tags : \"applied to\"\n  users ||--o{ bookmarks : \"saves\"\n  interviews ||--o{ bookmarks : \"bookmarked in\"\n  users ||--o{ comments : \"writes\"\n  interviews ||--o{ comments : \"receives\"\n  users ||--o{ referrals : \"refers\"\n  users ||--o{ referrals : \"referred by\"\n  users ||--|| user_preferences : \"has\"\n  users ||--o{ read_history : \"tracks\"\n  interviews ||--o{ read_history : \"read in\"\n  users ||--o{ notifications : \"receives\"\n  users ||--o{ fcm_tokens : \"registers\"\n  interviews ||--o| crawl_jobs : \"sourced from\"\n```","x":-580,"y":-30,"width":2580,"height":1190}
